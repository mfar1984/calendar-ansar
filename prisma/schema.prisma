generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  phone     String?
  notifyEmail Boolean @default(true)
  notifySms   Boolean @default(false)
  emailVerified Boolean @default(false)
  verifyToken   String?  @unique
  verifyExpiry  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calendars       Calendar[]
  sharedCalendars CalendarShare[] @relation("SharedWithUser")
}

model Calendar {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#3B82F6")
  token       String   @unique // untuk ICS feed URL
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  events Event[]
  shares CalendarShare[]
}

model Event {
  id          String   @id @default(cuid())
  uid         String   @unique // untuk CalDAV sync (globally unique)
  calendarId  String
  title       String
  description String?  @db.Text
  location    String?
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean  @default(false)
  etag        String   // untuk CalDAV change detection

  // Outlook-style fields
  status      String   @default("busy")     // free | working_elsewhere | tentative | busy | out_of_office
  reminder    Int?                           // minutes before event (null = no reminder)
  category    String?                        // category label
  categoryColor String?                      // hex color for category
  isPrivate   Boolean  @default(false)

  // Recurring event
  recurrence  String?  @db.Text             // JSON: { type, interval, daysOfWeek, endDate, count }
  recurringId String?                        // parent event uid for recurring instances

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
}

model CalendarShare {
  id         String   @id @default(cuid())
  calendarId String
  userId     String   // user yang di-share kepada
  permission String   @default("read") // "read" atau "write"
  createdAt  DateTime @default(now())

  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  user     User     @relation("SharedWithUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([calendarId, userId])
}
